---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getOrderedCollection, getEntryHref } from "../../lib/content";

const methods = await getOrderedCollection("methodologies");
const topicOptions = [...new Set(methods.flatMap((entry) => entry.data.tags))].sort();
---
<BaseLayout title="Advanced Methodologies | Market Research Notes" description="Market research methodology pages with consistent templates and practical notes.">
  <section class="page-intro">
    <div class="shell">
      <p class="eyebrow">Advanced Methodologies</p>
      <h1>Choose, compare, and explain methods with a consistent structure</h1>
      <p class="lede">Each page is organized to support practical use: applicability, inputs, outputs, limitations, interpretation, communication, and implementation notes.</p>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div class="filter-card">
        <label><span class="helper">Filter by topic tag</span><select class="select" id="method-tag-filter"><option value="">All topics</option>{topicOptions.map((tag) => <option value={tag}>{tag}</option>)}</select></label>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div class="collection-grid" id="methodology-grid">
        {methods.map((entry) => (
          <article class="method-card" data-methodology-card data-tags={entry.data.tags.join("|")}>
            <div>
              <h3><a href={getEntryHref(entry)}>{entry.data.title}</a></h3>
              <p>{entry.data.description}</p>
            </div>
            <ul class="tag-list">{entry.data.tags.map((tag) => <li class="tag">{tag}</li>)}</ul>
          </article>
        ))}
      </div>
      <p class="empty-state" id="methodology-empty" hidden>No methodology pages match the current tag filter.</p>
    </div>
  </section>
  <script is:inline>
    const filter = document.getElementById("method-tag-filter");
    const cards = Array.from(document.querySelectorAll("[data-methodology-card]"));
    const empty = document.getElementById("methodology-empty");
    const updateMethodCards = () => {
      const selected = filter instanceof HTMLSelectElement ? filter.value : "";
      let visibleCount = 0;
      cards.forEach((card) => {
        const tags = (card.dataset.tags || "").split("|");
        const visible = !selected || tags.includes(selected);
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });
      if (empty) empty.hidden = visibleCount !== 0;
    };
    filter?.addEventListener("change", updateMethodCards);
    updateMethodCards();
  </script>
</BaseLayout>
