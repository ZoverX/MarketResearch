---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getOrderedCollection, getEntryHref } from "../../lib/content";

const basics = await getOrderedCollection("basics");
const basicPages = await Promise.all(
  basics.map(async (entry) => ({
    entry,
    rendered: await entry.render()
  }))
);
---
<BaseLayout title="Basic Info | Market Research Notes" description="Foundational market research concepts, project process, and data basics.">
  <section class="page-intro">
    <div class="shell">
      <p class="eyebrow">Basic Info</p>
      <h1>Foundations before methods</h1>
      <p class="lede">Use these pages to ground the project lifecycle, data types, supplier landscape, and the qualitative versus quantitative split.</p>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div class="panel basics-tabs-shell">
        <div class="basics-tabs-head">
          <div>
            <h2>Basic Info topics</h2>
            <p class="helper">Choose a topic card to open the full content in a popup, or use the direct article link if you want the standalone page.</p>
          </div>
        </div>

        <div class="basics-cards-grid" data-basics-modal-root>
          <div class="collection-grid">
            {
              basicPages.map(({ entry }) => (
                <article class="article-card basics-topic-card">
                  <button
                    class="basics-topic-button"
                    type="button"
                    aria-haspopup="dialog"
                    aria-controls={`basic-modal-${entry.slug}`}
                    data-modal-trigger
                    data-target={entry.slug}
                  >
                    <span class="eyebrow">{entry.data.section}</span>
                    <h3>{entry.data.title}</h3>
                    <p>{entry.data.description}</p>
                    <ul class="tag-list">
                      {entry.data.tags.map((tag) => (
                        <li class="tag">{tag}</li>
                      ))}
                    </ul>
                  </button>
                  <a class="basics-tab-link" href={getEntryHref(entry)}>Open article</a>
                </article>
              ))
            }
          </div>

          <div class="basics-modal-backdrop" data-modal-backdrop hidden>
            {
              basicPages.map(({ entry, rendered }) => {
                const { Content } = rendered;
                return (
                  <article
                    class="content-panel basics-modal-panel"
                    role="dialog"
                    aria-modal="true"
                    aria-labelledby={`basic-modal-title-${entry.slug}`}
                    id={`basic-modal-${entry.slug}`}
                    hidden
                    data-modal-panel
                    data-panel={entry.slug}
                  >
                    <div class="basics-modal-toolbar">
                      <div class="basics-panel-meta">
                        <p class="eyebrow">{entry.data.section}</p>
                        <h2 id={`basic-modal-title-${entry.slug}`}>{entry.data.title}</h2>
                        <p class="lede">{entry.data.description}</p>
                        <ul class="tag-list">
                          {entry.data.tags.map((tag) => (
                            <li class="tag">{tag}</li>
                          ))}
                        </ul>
                      </div>
                      <button class="basics-modal-close" type="button" data-modal-close aria-label="Close topic">
                        Close
                      </button>
                    </div>
                    <div class="basics-modal-content">
                      <Content />
                    </div>
                    <p class="helper">
                      Standalone page:
                      {" "}
                      <a href={getEntryHref(entry)}>open article</a>
                    </p>
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const modalRoots = document.querySelectorAll("[data-basics-modal-root]");

    modalRoots.forEach((root) => {
      const triggers = Array.from(root.querySelectorAll("[data-modal-trigger]"));
      const panels = Array.from(root.querySelectorAll("[data-modal-panel]"));
      const closeButtons = Array.from(root.querySelectorAll("[data-modal-close]"));
      const backdrop = root.querySelector("[data-modal-backdrop]");
      let activeTrigger = null;

      const closeModal = () => {
        panels.forEach((panel) => {
          panel.hidden = true;
        });
        if (backdrop) {
          backdrop.hidden = true;
          document.body.classList.remove("modal-open");
        }
        if (activeTrigger) activeTrigger.focus();
      };

      const openModal = (target, trigger) => {
        panels.forEach((panel) => {
          panel.hidden = panel.dataset.panel !== target;
        });
        if (backdrop) {
          backdrop.hidden = false;
          document.body.classList.add("modal-open");
        }
        activeTrigger = trigger;
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => openModal(trigger.dataset.target, trigger));
      });

      closeButtons.forEach((button) => {
        button.addEventListener("click", closeModal);
      });

      backdrop?.addEventListener("click", (event) => {
        if (event.target === backdrop) closeModal();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && backdrop && !backdrop.hidden) closeModal();
      });
    });
  </script>
</BaseLayout>
