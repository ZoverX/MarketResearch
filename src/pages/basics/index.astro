---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getOrderedCollection, getEntryHref } from "../../lib/content";

const basics = await getOrderedCollection("basics");
const basicPages = await Promise.all(
  basics.map(async (entry) => ({
    entry,
    rendered: await entry.render()
  }))
);
---
<BaseLayout title="Basic Info | Market Research Notes" description="Foundational market research concepts, project process, and data basics.">
  <section class="page-intro">
    <div class="shell">
      <p class="eyebrow">Basic Info</p>
      <h1>Foundations before methods</h1>
      <p class="lede">Use these pages to ground the project lifecycle, data types, supplier landscape, and the qualitative versus quantitative split.</p>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div class="panel basics-tabs-shell">
        <div class="basics-tabs-head">
          <div>
            <h2>Basic Info topics</h2>
            <p class="helper">Select a tab to read the topic in place, or use the dedicated page link if you want the standalone article view.</p>
          </div>
        </div>

        <div class="basics-tabs" data-basics-tabs>
          <div class="basics-tab-list" role="tablist" aria-label="Basic Info topics">
            {
              basicPages.map(({ entry }, index) => (
                <div class="basics-tab-item">
                  <button
                    class="basics-tab-button"
                    type="button"
                    role="tab"
                    id={`basic-tab-${entry.slug}`}
                    aria-controls={`basic-panel-${entry.slug}`}
                    aria-selected={index === 0 ? "true" : "false"}
                    tabindex={index === 0 ? "0" : "-1"}
                    data-tab-button
                    data-target={entry.slug}
                  >
                    {entry.data.title}
                  </button>
                  <a class="basics-tab-link" href={getEntryHref(entry)}>Open article</a>
                </div>
              ))
            }
          </div>

          <div class="basics-tab-panels">
            {
              basicPages.map(({ entry, rendered }, index) => {
                const { Content } = rendered;
                return (
                  <article
                    class="content-panel basics-tab-panel"
                    role="tabpanel"
                    id={`basic-panel-${entry.slug}`}
                    aria-labelledby={`basic-tab-${entry.slug}`}
                    hidden={index !== 0}
                    data-tab-panel
                    data-panel={entry.slug}
                  >
                    <div class="basics-panel-meta">
                      <p class="eyebrow">{entry.data.section}</p>
                      <h2>{entry.data.title}</h2>
                      <p class="lede">{entry.data.description}</p>
                      <ul class="tag-list">
                        {entry.data.tags.map((tag) => (
                          <li class="tag">{tag}</li>
                        ))}
                      </ul>
                      <p class="helper">
                        Standalone page:
                        {" "}
                        <a href={getEntryHref(entry)}>open article</a>
                      </p>
                    </div>
                    <Content />
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const tabContainers = document.querySelectorAll("[data-basics-tabs]");

    tabContainers.forEach((container) => {
      const buttons = Array.from(container.querySelectorAll("[data-tab-button]"));
      const panels = Array.from(container.querySelectorAll("[data-tab-panel]"));

      const activateTab = (target) => {
        buttons.forEach((button) => {
          const active = button.dataset.target === target;
          button.setAttribute("aria-selected", String(active));
          button.setAttribute("tabindex", active ? "0" : "-1");
          button.classList.toggle("is-active", active);
        });

        panels.forEach((panel) => {
          panel.hidden = panel.dataset.panel !== target;
        });
      };

      buttons.forEach((button, index) => {
        button.addEventListener("click", () => activateTab(button.dataset.target));
        button.addEventListener("keydown", (event) => {
          if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
          event.preventDefault();
          const delta = event.key === "ArrowRight" ? 1 : -1;
          const nextIndex = (index + delta + buttons.length) % buttons.length;
          buttons[nextIndex].focus();
          activateTab(buttons[nextIndex].dataset.target);
        });
      });

      const initial = buttons.find((button) => button.getAttribute("aria-selected") === "true");
      if (initial) activateTab(initial.dataset.target);
    });
  </script>
</BaseLayout>
