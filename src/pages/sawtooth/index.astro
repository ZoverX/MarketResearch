---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CollectionList from "../../components/CollectionList.astro";
import { getOrderedCollection, getEntryHref } from "../../lib/content";

const pages = await getOrderedCollection("sawtooth");
---
<BaseLayout title="Sawtooth | Market Research Notes" description="Starter section for Sawtooth-specific workflow notes and setup guidance.">
  <section class="page-intro">
    <div class="shell">
      <p class="eyebrow">Sawtooth</p>
      <h1>Starter section for future Sawtooth notes</h1>
      <p class="lede">This section launches as a shell so you have a clear place for future Sawtooth setup notes, model execution steps, and reporting tips.</p>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <CollectionList items={pages.map((entry) => ({ href: getEntryHref(entry), title: entry.data.title, description: entry.data.description, tags: entry.data.tags }))} />
    </div>
  </section>
</BaseLayout>
