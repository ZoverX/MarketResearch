---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { collectionOrder, getEntryHref } from "../lib/content";

const methods = collectionOrder(await getCollection("methodologies"));
const stageOptions = [...new Set(methods.flatMap((entry) => entry.data.chooserStage))].sort();
const goalOptions = [...new Set(methods.flatMap((entry) => entry.data.chooserGoal))].sort();
const dataOptions = [...new Set(methods.flatMap((entry) => entry.data.chooserData))].sort();
const outputOptions = [...new Set(methods.flatMap((entry) => entry.data.chooserOutput))].sort();
---
<BaseLayout title="Method Chooser | Market Research Notes" description="Choose a market research method by project stage, goal, data, and output.">
  <section class="page-intro">
    <div class="shell">
      <p class="eyebrow">Decision support</p>
      <h1>Method chooser</h1>
      <p class="lede">This tool is intentionally lightweight. It helps narrow the field based on what problem you are solving, what kind of data you have, and what type of output you need to explain.</p>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div class="filter-card">
        <form id="method-chooser-form" class="filters">
          <label><span class="helper">Project stage</span><select class="select" name="stage"><option value="">Any stage</option>{stageOptions.map((option) => <option value={option}>{option}</option>)}</select></label>
          <label><span class="helper">Primary goal</span><select class="select" name="goal"><option value="">Any goal</option>{goalOptions.map((option) => <option value={option}>{option}</option>)}</select></label>
          <label><span class="helper">Data type</span><select class="select" name="data"><option value="">Any data</option>{dataOptions.map((option) => <option value={option}>{option}</option>)}</select></label>
          <label><span class="helper">Expected output</span><select class="select" name="output"><option value="">Any output</option>{outputOptions.map((option) => <option value={option}>{option}</option>)}</select></label>
        </form>
        <p class="helper">Recommendation logic stays content-driven: updating method frontmatter updates this chooser automatically.</p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="shell">
      <div id="method-results" class="collection-grid">
        {methods.map((entry) => (
          <article class="method-card" data-method-card data-stage={entry.data.chooserStage.join("|")} data-goal={entry.data.chooserGoal.join("|")} data-data={entry.data.chooserData.join("|")} data-output={entry.data.chooserOutput.join("|")}>
            <div>
              <h3><a href={getEntryHref(entry)}>{entry.data.title}</a></h3>
              <p>{entry.data.description}</p>
            </div>
            <ul class="tag-list">{entry.data.tags.map((tag) => <li class="tag">{tag}</li>)}</ul>
          </article>
        ))}
      </div>
      <p id="method-empty" class="empty-state" hidden>No methods match that combination yet. Relax one filter or add a new method entry to the collection.</p>
    </div>
  </section>
  <script is:inline>
    const form = document.getElementById("method-chooser-form");
    const cards = Array.from(document.querySelectorAll("[data-method-card]"));
    const empty = document.getElementById("method-empty");
    const matches = (cardValue, selected) => !selected || cardValue.split("|").includes(selected);
    const updateCards = () => {
      if (!form) return;
      const data = new FormData(form);
      const selected = {
        stage: String(data.get("stage") || ""),
        goal: String(data.get("goal") || ""),
        data: String(data.get("data") || ""),
        output: String(data.get("output") || "")
      };
      let visibleCount = 0;
      cards.forEach((card) => {
        const visible = matches(card.dataset.stage || "", selected.stage) && matches(card.dataset.goal || "", selected.goal) && matches(card.dataset.data || "", selected.data) && matches(card.dataset.output || "", selected.output);
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });
      if (empty) empty.hidden = visibleCount !== 0;
    };
    form?.addEventListener("change", updateCards);
    updateCards();
  </script>
</BaseLayout>
