---
interface Props {
  entry: any;
}

const { entry } = Astro.props;
const data = entry.data;
---
<div class="detail-grid">
  <section class="detail-panel">
    <h3>When to use it</h3>
    <ul>{data.whenToUse.map((item: string) => <li>{item}</li>)}</ul>
  </section>
  <section class="detail-panel">
    <h3>When not to use it</h3>
    <ul>{data.whenNotToUse.map((item: string) => <li>{item}</li>)}</ul>
  </section>
  <section class="detail-panel">
    <h3>Inputs required</h3>
    <ul>{data.inputsRequired.map((item: string) => <li>{item}</li>)}</ul>
  </section>
  <section class="detail-panel">
    <h3>Typical outputs</h3>
    <ul>{data.typicalOutputs.map((item: string) => <li>{item}</li>)}</ul>
  </section>
</div>

<details class="details" open>
  <summary>Simple example</summary>
  <div class="details-body"><p>{data.simpleExample}</p></div>
</details>
<details class="details">
  <summary>Strengths</summary>
  <div class="details-body"><ul>{data.strengths.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>Limitations</summary>
  <div class="details-body"><ul>{data.limitations.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>Common mistakes</summary>
  <div class="details-body"><ul>{data.commonMistakes.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>How I use it in practice</summary>
  <div class="details-body"><p>{data.practicalUse}</p></div>
</details>
<details class="details">
  <summary>What is outputted</summary>
  <div class="details-body"><ul>{data.outputted.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>How to interpret the output</summary>
  <div class="details-body"><ul>{data.interpretation.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>How to communicate to clients</summary>
  <div class="details-body"><ul>{data.clientCommunication.map((item: string) => <li>{item}</li>)}</ul></div>
</details>
<details class="details">
  <summary>Displayr / Q implementation notes</summary>
  <div class="details-body"><ul>{data.displayrNotes.map((item: string) => <li>{item}</li>)}</ul></div>
</details>

<section class="demo-panel">
  <p class="eyebrow">{data.demoType === "interactive" ? "Mini demo" : "Visual placeholder"}</p>
  <h3>{data.demoTitle ?? "Demo block"}</h3>
  <p>{data.demoSummary ?? "Add screenshots, diagrams, or an explanatory walkthrough here."}</p>
  <div class="card">
    <p class="helper">
      {
        data.demoType === "interactive"
          ? "This method is marked as a good candidate for a future teaching demo, but v1 keeps the site lightweight for GitHub Pages."
          : "Recommended placeholder: chart screenshot, process diagram, output interpretation notes, and one short caption on what to inspect first."
      }
    </p>
  </div>
</section>
