---
interface Item {
  href: string;
  title: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---
{items.length > 0 && (
  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <h2>Related topics</h2>
          <p>Jump to connected concepts, techniques, or implementation notes.</p>
        </div>
      </div>
      <div class="card-grid">
        {items.map((item) => (
          <article class="card">
            <h3><a href={item.href}>{item.title}</a></h3>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
