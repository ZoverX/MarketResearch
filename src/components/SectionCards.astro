---
interface Item {
  href: string;
  title: string;
  description: string;
  meta?: string;
}

interface Props {
  heading: string;
  intro: string;
  items: Item[];
}

const { heading, intro, items } = Astro.props;
---
<section class="section">
  <div class="shell">
    <div class="section-head">
      <div>
        <h2>{heading}</h2>
        <p>{intro}</p>
      </div>
    </div>
    <div class="card-grid">
      {items.map((item) => (
        <article class="card">
          <div>
            <h3><a href={item.href}>{item.title}</a></h3>
            <p>{item.description}</p>
          </div>
          {item.meta && <p class="meta">{item.meta}</p>}
        </article>
      ))}
    </div>
  </div>
</section>
