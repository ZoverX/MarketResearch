        "type": "string"
      }
    },
    "chooserGoal": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chooserData": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chooserOutput": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
