    "inputsRequired": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "typicalOutputs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "simpleExample": {
      "type": "string"
    },
    "strengths": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
