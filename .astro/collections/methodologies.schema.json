      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "displayrNotes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demoType": {
      "default": "placeholder",
      "type": "string",
      "enum": [
        "interactive",
        "placeholder"
      ]
    },
    "demoTitle": {
      "type": "string"
    },
    "demoSummary": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
