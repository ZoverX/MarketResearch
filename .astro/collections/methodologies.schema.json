      "type": "string"
    },
    "whenToUse": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "whenNotToUse": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
